# Exclude all files in platform-specific folders regardless of depth
android/** linguist-vendored
ios/** linguist-vendored
linux/** linguist-vendored
macos/** linguist-vendored
windows/** linguist-vendored

# Force all .dart files to be detectable
*.dart linguist-detectable=true

# Explicitly hide all C++ related files from stats
**/*.cpp linguist-vendored
**/*.cc linguist-vendored
**/*.h linguist-vendored
